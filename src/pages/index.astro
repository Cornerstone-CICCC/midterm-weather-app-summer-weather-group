			let cities;
			const PLACES_API_KEY = "https://api.placekit.co/search";
			let currentResults: LocationData[] = [];
      		let selectedLocation: LocationData | undefined | null = undefined;
			function renderDropdown(results : LocationData[]){
				const dropdown = document.getElementById("dropdown");
				dropdown.replaceChildren();
				if(results.length===0){
					dropdown.append(`<li>No results found</li>`);
					dropdown?.classList.remove("hidden");
					return;
				}
				const radios = document.querySelectorAll('input[name="radioCB"]');
					radios.forEach(radio => radio.checked = false);
				results.forEach((item : LocationData, index) =>{
					const postal = item.zipcode && item.zipcode.length > 0 ? item.zipcode[0]:"=";
					const li = `<li data-index="${index}">${item.name} (${postal})</li>`;
					const element = htmlToElement(li);
					dropdown?.append(element);
					//console.log(item);
					
				})
				dropdown?.classList.remove("hidden");
				cities = results;
			}

			function htmlToElement(html) {
  				const template = document.createElement('template');
  				template.innerHTML = html.trim();
  				return template.content.firstElementChild;
			}

			async function searchPlaces(query: string) {
				const response = await fetch(PLACES_API_KEY, {
          			method: "POST",
          			headers: {
            			"Content-Type": "application/json",
           				"x-placekit-api-key":
              			"pk_jxXvDSfDFgK702r0wxshJvHjdoLMd1Q7i+CHbYmE+HY=",
        			},
          			body: JSON.stringify({ query }),
        		});
				const data = await response.json();
        		return data.results;
			}

			async function runSearch() {
        		let query: string = (document.getElementById("searchBar1").value as string).trim();
        			if (!query) {
          				alert("Please enter a search query.");
          				return;
        			}
        			document.getElementById("dropdown")?.classList.add("hidden");
        			currentResults = await searchPlaces(query);
			        renderDropdown(currentResults);
      		}
			let weather;
			let liChild : HTMLInputElement;
			document.getElementById('dropdown')?.addEventListener('click', async (e) =>{
									
				liChild = e.target.closest('li');
				if (liChild){
					let index = liChild.dataset.index;
					weather = await getWeatherInfo(cities[index].lat, cities[index].lng);

					document.getElementById('cityNameID').innerText = liChild.innerText;
					const fiveDays = document.getElementById('fiveDaysId');
					let dayCount = 0;
					fiveDays.querySelectorAll('.dayInfo').forEach(async (element, i) => {
						if (i>26){
							i = 0;
						}
						if(!(i%5==0)){
								element.innerHTML = `<div class="dayInfo">${weather.daily.time[dayCount]}</div>`;
						}
						if(i%5==1){
							//element.innerHTML = `<div class="dayInfo"></div>`;
						}
						if(i%5==2){
							element.innerHTML = `<div class="dayInfo"><img src="${weatherCodes[weather.daily.weather_code[dayCount]].day.image}"></div>`;
						}
						if(i%5==3){
							element.innerHTML = `<div class="dayInfo">${weatherCodes[weather.daily.weather_code[dayCount]].day.description}</div>`;
						}
						if(i%5==4){
							element.innerHTML = `<div class="dayInfo">${weather.daily.temperature_2m_max[dayCount]}</div>`;
							dayCount++;
						}
						//console.log(i + " ");
						//console.log(element);
						if (i>25){i = 0;}
					});
					dayCount = 0;
					document.getElementById("dropdown")?.classList.add('hidden');
					fiveDays.classList.remove('hidden');

					const each = document.querySelectorAll('.eachDay');
					let intIndex = 0;
					
					for (let i = 0; i < 5; i++) {
						each[i].addEventListener('click', ()=>{
							populateIntervals(i);
							document.getElementById('eightIntervalsID')?.classList.remove('hidden')
						});
					}
				}

				
			})

			function populateIntervals(index : number){
				const eachInt = document.querySelectorAll('.eachInterval');
				let divs;
				let intervals = 0;
				eachInt.forEach(element => {
					divs = element.getElementsByTagName('div');
					//divs[0].innerText = '';
					divs[1].innerText = 'pic';
					divs[2].innerText = 'desc';
					divs[3].innerText = weather.hourly.temperature_2m[index * 24 + intervals];
					intervals += 3;

				});

			}

			async function getWeatherInfo(lat: number, lng: number) {
          			const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&daily=weather_code,temperature_2m_max,precipitation_sum,wind_speed_10m_max&hourly=temperature_2m,rain,wind_speed_10m&current=temperature_2m,rain,wind_speed_10m&timezone=auto&forecast_days=5`);
        			const data = await response.json();
					console.log(data);
          			return data;
       			}
