				const elements = document.querySelectorAll('.cityItem');
				elements.forEach(element => {
					if(element.textContent.trim().slice(0, -1) == addElement){
						alert("City already added");
						check = false;
						return;
					}
				});
				if(check){
					add += addElement;
					add += `<button class="removeCity">X</button></div>`
