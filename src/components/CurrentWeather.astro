---
---

<div class="current-weather">
  <div class="current-weather__header">
    <p class="current-weather__city" id="city-name">--</p>
    <p class="current-weather__time" id="weather-time">--</p>
  </div>

  <div class="current-weather__main">
    <div class="current-weather__temp-group">
      <span class="current-weather__temp" id="temperature">--</span>
      <div class="current-weather__temp-range">
        <span class="current-weather__temp-max" id="temp-max">--</span>
        <span class="current-weather__temp-min" id="temp-min">--</span>
      </div>
    </div>
    <img class="current-weather__icon" id="weather-icon" src="" alt="" />
  </div>

  <p class="current-weather__condition" id="condition">--</p>

  <ul class="current-weather__details">
    <li class="current-weather__detail-item">
      <span class="current-weather__detail-label">Humidity</span>
      <span class="current-weather__detail-value" id="humidity">--</span>
    </li>
    <li class="current-weather__detail-item">
      <span class="current-weather__detail-label">Wind</span>
      <span class="current-weather__detail-value" id="wind-speed">--</span>
    </li>
    <li class="current-weather__detail-item">
      <span class="current-weather__detail-label">Precipitation</span>
      <span class="current-weather__detail-value" id="precipitation">--</span>
    </li>
    <li class="current-weather__detail-item">
      <span class="current-weather__detail-label">UV Index</span>
      <span class="current-weather__detail-value" id="uv-index">--</span>
    </li>
  </ul>
</div>

<style lang="scss" is:global>
  @use '@/styles/abstracts/variables' as *;

  .current-weather {
    position: relative;
    color: $text-color;
    border-radius: $radius-md;
    padding: $spacing-xl;
    box-shadow: $shadow-md;
    background-color: $surface-color;
    background-size: cover;
    background-position: center;
    overflow: hidden;

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.2);
      border-radius: $radius-md;
    }

    & > * {
      position: relative;
    }

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: $spacing-md;
    }

    &__city {
      font-size: $font-size-lg;
      font-weight: bold;
    }

    &__time {
      font-size: $font-size-sm;
      color: $text-muted;
    }

    &__main {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: $spacing-sm;
    }

    &__temp-group {
      display: flex;
      align-items: baseline;
      gap: $spacing-md;
    }

    &__temp {
      font-size: $font-size-2xl;
      font-weight: bold;
    }

    &__temp-range {
      display: flex;
      flex-direction: column;
      gap: $spacing-xs;
      font-size: $font-size-sm;
    }

    &__icon {
      width: 80px;
      height: 80px;
      filter: brightness(0) invert(1);
    }

    &__temp-max {
      color: $warning-color;
    }

    &__temp-min {
      color: $primary-color;
    }

    &__condition {
      font-size: $font-size-md;
      color: $text-muted;
      margin-bottom: $spacing-lg;
    }

    &__details {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: $spacing-sm $spacing-lg;
    }

    &__detail-item {
      display: flex;
      flex-direction: column;
      gap: $spacing-xs;
    }

    &__detail-label {
      font-size: $font-size-sm;
      color: $text-muted;
    }

    &__detail-value {
      font-size: $font-size-md;
      font-weight: bold;
    }
  }
</style>
